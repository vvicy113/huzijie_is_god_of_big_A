# ======================================================
# 股票回测与分析系统 — 运行配置文件
# ======================================================
# 将此文件复制为 run.properties 并根据需要修改参数。
# 系统启动时如发现 run.properties 存在，将自动按此配置运行，
# 不再进入交互式菜单。
# ======================================================

# ---- 运行模式 ----
# 可选值: backtest | analysis | import | stats
mode=backtest

# ======================================================
# 回测配置 (mode=backtest 时生效)
# ======================================================

# 策略名称，可选值: 动量突破(标准) | 动量突破(激进) | 动量突破(稳健) | 底部反转
# 也可以在 StrategyRegistry 中注册自定义策略
backtest.strategy=动量突破(标准)

# 回测日期范围 (yyyy-MM-dd，留空=全部)
backtest.date.from=2024-01-01
backtest.date.to=2024-12-31

# ---- 引擎参数 ----
# 初始资金（元）
backtest.capital=100000

# 最多同时持仓股票数
backtest.maxPositions=5

# 资金使用比例 (0~1)
backtest.cashRatio=1.0

# 佣金率（默认万2.5）
backtest.commissionRate=0.00025

# 最低佣金（元）
backtest.minCommission=5.0

# 印花税率（仅卖出，默认千1）
backtest.stampTaxRate=0.001

# ---- 风控参数 ----
# 止损百分比（-1=禁用），例如 8.0 表示亏损8%强制卖出
backtest.stopLossPct=-1

# 止盈百分比（-1=禁用），例如 20.0 表示盈利20%强制卖出
backtest.takeProfitPct=-1

# 最大持仓天数（-1=不限）
backtest.maxHoldingDays=-1

# 回测结束时是否强制清仓
backtest.forceCloseAtEnd=true

# 满仓时是否卖出低分换高分
backtest.replaceLowerScored=false

# 是否允许对已持仓股票加仓
backtest.allowAddPosition=false

# 无风险利率（用于夏普比率计算）
backtest.riskFreeRate=0.02

# ======================================================
# 关联分析配置 (mode=analysis 时生效)
# ======================================================

# 主分析股票代码
analysis.primaryCode=600519

# 对比股票代码（逗号分隔）
analysis.compareCodes=000858,002304,600809

# ======================================================
# 数据导入配置 (mode=import 时生效)
# ======================================================

# 导入年份: 2023 | 2024 | 2025 | all
import.year=all

# ======================================================
# 数据库统计 (mode=stats 时生效，无需额外参数)
# ======================================================
