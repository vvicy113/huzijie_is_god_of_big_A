# ======================================================
# 股票回测与分析系统 — 运行配置文件
# ======================================================
# 复制为 run.properties，修改参数后编译运行。
# ======================================================

# ---- 运行模式 ----
# 1=回测  2=关联分析  3=数据导入  4=数据库统计
mode=1

# ======================================================
# 回测策略组装 (mode=1 时生效)
# ======================================================
# 通过配置文件自由组合选股器链和打分器链，无需写 Java 代码。

# ---- 选股器链 ----
# 按顺序执行，可任意组合。所有可用 code：
# ======== 基础 ========
#   1    = 全量主板
# ======== 成交量 ========
#   201  = 成交量筛选(20日均量 × 1.5倍)
#   202  = 成交量筛选(10日均量 × 2.0倍)
#   1101 = 缩量(≤20日均量 × 0.5)
#   1601 = 单日爆量(>前日×3)
#   1602 = 单日爆量(>前日×5)
# ======== 涨跌 ========
#   301  = 涨跌幅筛选(-2% ~ 10%)
#   302  = 涨跌幅筛选(-5% ~ 10%)
#   1901 = 涨停板(≥9.5%)
# ======== 均线 ========
#   401  = 均线多头(5日 > 20日)
#   402  = 均线多头(10日 > 30日)
#   801  = 5日均线乖离率 < 3%
#   802  = 20日均线乖离率 < 5%
#   1701 = 均线金叉(5×20)
#   1702 = 均线金叉(10×30)
# ======== 突破/新高 ========
#   501  = 20日新高
#   502  = 60日新高
#   901  = 跳空高开 > 2%
# ======== K线形态 ========
#   601  = 3连阳
#   602  = 5连阳
#   1301 = 长下影线(≥实体×2)
#   2001 = K线实体占比(≥50%)
# ======== 波动 ========
#   701  = 振幅筛选(3% ~ 10%)
#   702  = 振幅筛选(5% ~ 15%)
# ======== 动量 ========
#   1501 = 10日动量(5% ~ 30%)
#   1502 = 20日超跌(-10% ~ 0%)
# ======== 趋势 ========
#   1801 = 上涨趋势(20日中≥60%)
#   1802 = 上涨趋势(10日中≥70%)
# ======== 位置 ========
#   1401 = 底部区域(20日位置0%~30%)
#   1402 = 强势区域(20日位置70%~100%)
# ======== 布林 ========
#   1201 = 布林下轨(20日,2σ)
#   1202 = 布林收口(带宽<5%)
# ======== 成交额 ========
#   1001 = 成交额 > 1亿
#   1002 = 成交额 > 5亿
backtest.selector.codes=1,201,401

# ---- 打分器链 ----
# 打分结果用权重加权求和。所有可用 code：
#   501 = 10日动量打分
#   502 = 20日动量打分
#   601 = 5日量比打分
#   602 = 20日量比打分
#   701 = 5日乖离打分
#   702 = 20日乖离打分
#   801 = 振幅打分
#   802 = 10日趋势强度打分
#   803 = 20日趋势强度打分
backtest.scorer.codes=501,601,802

# 打分权重（与 scorer.codes 一一对应，和应为 1.0）
backtest.scorer.weights=0.5,0.3,0.2

# 买入分数阈值（综合分超此值生成 BUY 信号，默认 60）
backtest.buyThreshold=60

# ======================================================
# 回测通用配置
# ======================================================
backtest.date.from=2024-01-01
backtest.date.to=2024-12-31
backtest.capital=100000
backtest.maxPositions=5
backtest.cashRatio=1.0
backtest.commissionRate=0.00025
backtest.minCommission=5.0
backtest.stampTaxRate=0.001

# ---- 风控 ----
backtest.stopLossPct=-1
backtest.takeProfitPct=-1
backtest.maxHoldingDays=-1
backtest.forceCloseAtEnd=true
backtest.replaceLowerScored=false
backtest.allowAddPosition=false
backtest.riskFreeRate=0.02

# ======================================================
# 关联分析 (mode=2)
# ======================================================
analysis.primaryCode=600519
analysis.compareCodes=000858,002304,600809

# ======================================================
# 数据导入 (mode=3)
# ======================================================
import.year=all

# ======================================================
# 数据库统计 (mode=4)
# ======================================================
