# ======================================================
# 股票回测与分析系统 — 运行配置文件
# ======================================================
# 复制为 run.properties 后修改参数，系统启动时自动读取执行。
# ======================================================

# ---- 运行模式 ----
# 1=回测  2=关联分析  3=数据导入  4=数据库统计
mode=1

# ======================================================
# 回测配置 (mode=1 时生效)
# ======================================================

# 策略序号
# 1=动量突破(标准)  2=动量突破(激进)  3=动量突破(稳健)  4=底部反转
backtest.strategy=1

# 回测日期范围 (yyyy-MM-dd，留空=全部)
backtest.date.from=2024-01-01
backtest.date.to=2024-12-31

# ---- 引擎参数 ----
backtest.capital=100000
backtest.maxPositions=5
backtest.cashRatio=1.0
backtest.commissionRate=0.00025
backtest.minCommission=5.0
backtest.stampTaxRate=0.001

# ---- 风控参数 ----
backtest.stopLossPct=-1
backtest.takeProfitPct=-1
backtest.maxHoldingDays=-1
backtest.forceCloseAtEnd=true
backtest.replaceLowerScored=false
backtest.allowAddPosition=false
backtest.riskFreeRate=0.02

# ======================================================
# 关联分析配置 (mode=2 时生效)
# ======================================================
analysis.primaryCode=600519
analysis.compareCodes=000858,002304,600809

# ======================================================
# 数据导入配置 (mode=3 时生效)
# ======================================================
import.year=all

# ======================================================
# 数据库统计 (mode=4 时生效，无需额外参数)
# ======================================================
